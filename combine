UNION (
    SELECTCOLUMNS('Manual',"Week", 'Manual'[WEEK], "Release", 'Manual'[Associated release], "Type", "Manual"),
    SELECTCOLUMNS('Automation',"Week", 'Automation'[WEEK], "Release", 'Automation'[Associated release], "Type", "Automation")
)


CombinedTable = 
UNION (
    SELECTCOLUMNS('Manual',"Week", 'Manual'[Weekly], "Release", 'Manual'[Associated Release], "Type", "Manual"),
    SELECTCOLUMNS('Automation',"Week", 'Automation'[Weekly], "Release", 'Automation'[Associated Release], "Type", "Automation")
)



